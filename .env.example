# =================================================================
# PayWise environment variables — TEMPLATE ONLY (safe to commit).
# Copy to `.env` and fill in YOUR real values. Never put real keys here.
# =================================================================

# --- App ---
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000        # public URL Twilio/Nomba can reach (use ngrok in dev)

# --- MongoDB Atlas ---
# MUST be a replica set (Atlas is by default).
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?appName=<app>
MONGODB_DB_NAME=paywise

# --- OpenAI (the agent brain) ---
OPENAI_API_KEY=sk-<your-key>
OPENAI_MODEL=gpt-5

# --- ElevenLabs (Speech-to-Text) ---
ELEVENLABS_API_KEY=<your-key>
ELEVENLABS_STT_MODEL=scribe_v1

# --- Google Gemini (Text-to-Speech) ---
GEMINI_API_KEY=<your-key>
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Zephyr

# --- Twilio WhatsApp ---
TWILIO_ACCOUNT_SID=AC<your-sid>
TWILIO_AUTH_TOKEN=<your-token>
TWILIO_WHATSAPP_FROM=whatsapp:+<your-sender>   # Twilio sandbox or your sender

# --- Nomba ---
NOMBA_BASE_URL=https://sandbox.nomba.com
NOMBA_CLIENT_ID=<your-client-id>
NOMBA_CLIENT_KEY=<your-client-key>
NOMBA_ACCOUNT_ID=<parent-account-id>           # goes in the `accountId` header
NOMBA_SUB_ACCOUNT_ID=<sub-account-id>          # scopes VAs/transfers in the body
NOMBA_WEBHOOK_SECRET=<from-nomba>               # ask Nomba via the webhook form
NOMBA_VIRTUAL_ACCOUNT_TTL_HOURS=48              # fallback only — due_date drives expiry

# --- Reminder / collection account window ---
# Extra days past a debt's due_date before the temp collection account expires.
COLLECTION_GRACE_DAYS=2
